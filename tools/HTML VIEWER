<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HyperLive | In-Browser Local Server & Web Proxy</title>
    
    <!-- Tailwind CSS for Premium UI Styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- JSZip for exporting Workspaces -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <!-- Firebase SDK (Compat Version for ease of HTML integration) -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #020617; /* Slate 950 */
        }
        
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }

        /* Beautiful Custom Scrollbars */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; border: 2px solid #0f172a; }
        ::-webkit-scrollbar-thumb:hover { background: #6366f1; }

        .sandbox-iframe {
            width: 100%; height: 100%; border: none; background: #ffffff;
        }

        .tree-item-hover:hover { background-color: rgba(99, 102, 241, 0.15); color: #fff; }
        
        /* Proxy Toggle Switch Styling */
        .toggle-checkbox:checked { right: 0; border-color: #10b981; }
        .toggle-checkbox:checked + .toggle-label { background-color: #10b981; }

        /* Full Screen Drop Overlay */
        #global-drop-overlay {
            transition: opacity 0.2s ease, backdrop-filter 0.2s ease;
            pointer-events: none;
        }
        .drag-active #global-drop-overlay {
            opacity: 1; backdrop-filter: blur(8px); pointer-events: all;
        }

        /* Loading Spinner */
        .loader {
            border: 3px solid rgba(255,255,255,0.1);
            border-bottom-color: #6366f1;
            border-radius: 50%;
            display: inline-block;
            box-sizing: border-box;
            animation: rotation 1s linear infinite;
        }
        @keyframes rotation { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Line numbers synchronization */
        #editor-textarea {
            resize: none;
            outline: none;
            white-space: pre;
            overflow-x: auto;
        }
    </style>
</head>
<body class="text-slate-200 h-screen flex flex-col overflow-hidden selection:bg-indigo-500/30 relative">

    <!-- AUTH LOCK OVERLAY SCREEN -->
    <div id="auth-lock-screen" class="fixed inset-0 z-50 bg-slate-950 flex items-center justify-center p-4">
        <div class="relative w-full max-w-md">
            <!-- Decorative Backlight Blur -->
            <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-violet-600 rounded-2xl blur opacity-30 animate-pulse"></div>
            
            <div class="relative bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-2xl">
                <!-- Header / Brand -->
                <div class="text-center mb-8">
                    <div class="inline-flex p-3 bg-indigo-600/10 text-indigo-400 border border-indigo-500/20 rounded-2xl mb-4">
                        <i data-lucide="shield-check" class="w-8 h-8"></i>
                    </div>
                    <h2 class="text-2xl font-black text-white tracking-tight">Welcome to HyperLive</h2>
                    <p class="text-xs text-slate-400 mt-1">Please sign in to access your secure offline workspace sandbox</p>
                </div>

                <!-- Form Controls -->
                <div class="space-y-4">
                    <div id="auth-error-banner" class="hidden p-3 bg-rose-500/10 border border-rose-500/20 rounded-xl text-xs text-rose-400 flex items-center gap-2">
                        <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i>
                        <span id="auth-error-msg">Incorrect email or password.</span>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5">Email Address</label>
                        <input id="auth-email" type="email" placeholder="you@example.com" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5">Password</label>
                        <input id="auth-password" type="password" placeholder="••••••••" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition">
                    </div>

                    <!-- Sign In Button -->
                    <button id="auth-primary-btn" onclick="handleEmailPasswordAuth()" class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl text-xs transition shadow-lg shadow-indigo-600/15 flex items-center justify-center gap-2 mt-2">
                        <i data-lucide="log-in" class="w-4 h-4"></i>
                        <span id="auth-btn-label">Sign In to Dashboard</span>
                    </button>

                    <!-- Toggle Mode Link -->
                    <div class="text-center text-xs text-slate-400 mt-4">
                        <span id="auth-toggle-text">Don't have an account?</span>
                        <button onclick="toggleAuthMode()" id="auth-toggle-btn" class="text-indigo-400 hover:text-indigo-300 font-semibold ml-1 underline">Sign Up</button>
                    </div>

                    <div class="relative flex py-2 items-center">
                        <div class="flex-grow border-t border-slate-800"></div>
                        <span class="flex-shrink mx-4 text-[10px] text-slate-500 font-bold uppercase tracking-wider">or</span>
                        <div class="flex-grow border-t border-slate-800"></div>
                    </div>

                    <!-- Guest Mode Button -->
                    <button onclick="handleAnonymousAuth()" class="w-full py-2.5 bg-slate-800 hover:bg-slate-750 text-slate-300 border border-slate-700 font-semibold rounded-xl text-xs transition flex items-center justify-center gap-2">
                        <i data-lucide="user-cog" class="w-4 h-4 text-slate-400"></i>
                        <span>Continue as Guest</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- GLOBAL DRAG & DROP OVERLAY -->
    <div id="global-drop-overlay" class="fixed inset-0 z-50 opacity-0 bg-slate-950/80 flex flex-col items-center justify-center border-4 border-dashed border-indigo-500 m-4 rounded-3xl">
        <div class="bg-indigo-600 p-6 rounded-full mb-6 shadow-2xl shadow-indigo-500/50 animate-bounce">
            <i data-lucide="hard-drive-upload" class="w-16 h-16 text-white"></i>
        </div>
        <h2 class="text-4xl font-extrabold text-white mb-2 tracking-tight">Drop Folder to Host</h2>
        <p class="text-indigo-200 text-lg font-medium">Release your mouse to instantly spin up a local server.</p>
    </div>

    <!-- MAIN APP HEADER -->
    <header class="bg-slate-900 border-b border-slate-800 px-6 h-16 shrink-0 flex items-center justify-between z-20 shadow-md">
        <div class="flex items-center space-x-4">
            <div class="relative group cursor-pointer" onclick="switchMode('local')">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500 to-violet-600 rounded-xl blur opacity-60 group-hover:opacity-100 transition duration-200"></div>
                <div class="relative bg-slate-900 text-white p-2.5 rounded-xl border border-slate-700">
                    <i data-lucide="box" class="w-6 h-6"></i>
                </div>
            </div>
            <div>
                <h1 class="text-lg font-bold tracking-tight text-white flex items-center gap-2">
                    HyperLive <span class="text-[10px] bg-gradient-to-r from-indigo-500 to-violet-500 text-white px-2 py-0.5 rounded-full font-mono font-bold uppercase tracking-wider shadow-sm">Pro</span>
                </h1>
                <p class="text-[11px] text-slate-400 font-medium">In-Browser Local Host & Proxy Viewer</p>
            </div>
        </div>

        <!-- Mode Switcher -->
        <div class="flex bg-slate-950 p-1 rounded-xl border border-slate-800 shadow-inner">
            <button onclick="switchMode('local')" id="btn-mode-local" class="px-5 py-2 text-xs font-bold rounded-lg bg-indigo-600 text-white shadow-md shadow-indigo-900/50 transition flex items-center gap-2">
                <i data-lucide="folder-tree" class="w-4 h-4"></i>
                Local Workspace
            </button>
            <button onclick="switchMode('browser')" id="btn-mode-browser" class="px-5 py-2 text-xs font-bold rounded-lg text-slate-400 hover:text-slate-100 hover:bg-slate-800 transition flex items-center gap-2">
                <i data-lucide="globe" class="w-4 h-4"></i>
                Unrestricted Web
            </button>
        </div>

        <!-- Global Workspace Actions -->
        <div class="flex items-center space-x-3" id="header-local-actions">
            <!-- User Status Panel -->
            <div class="flex items-center gap-2 bg-slate-950/80 px-3.5 py-1.5 rounded-xl border border-slate-800/80 text-xs">
                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                <span id="active-user-badge" class="text-slate-300 font-semibold truncate max-w-[120px]">Guest User</span>
                <button onclick="handleSignOut()" class="text-[10px] font-bold text-rose-400 hover:text-rose-300 ml-2 border-l border-slate-800 pl-2 transition">Sign Out</button>
            </div>

            <button onclick="triggerFolderUpload()" class="flex items-center space-x-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white border border-slate-600 font-bold rounded-xl text-xs transition shadow-sm">
                <i data-lucide="folder-up" class="w-4 h-4 text-indigo-400"></i>
                <span>Upload Folder</span>
            </button>
            <input type="file" id="folder-upload-input" class="hidden" webkitdirectory directory multiple onchange="handleFolderUpload(event)">
            
            <button onclick="exportWorkspaceToZip()" id="btn-export-zip" class="hidden flex items-center space-x-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl text-xs transition shadow-md shadow-emerald-900/50">
                <i data-lucide="download" class="w-4 h-4"></i>
                <span>Download as .ZIP</span>
            </button>

            <div class="w-px h-6 bg-slate-700 mx-1"></div>
            
            <button onclick="clearAllWorkspaces()" class="flex items-center justify-center p-2 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 hover:text-rose-300 border border-rose-500/20 font-semibold rounded-xl transition" title="Clear Workspace Memory">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
            </button>
        </div>
    </header>

    <!-- MAIN APP CONTAINER -->
    <div class="flex-1 flex overflow-hidden relative bg-slate-950">

        <!-- ========================================== -->
        <!-- MODE 1: LOCAL FOLDER WORKSPACE ENGINE      -->
        <!-- ========================================== -->
        <div id="view-local-workspace" class="absolute inset-0 flex">
            <!-- SIDEBAR: SITES REGISTRY & FILE EXPLORER -->
            <aside class="w-72 bg-slate-900 border-r border-slate-800 flex flex-col shrink-0 z-10 shadow-xl">
                <!-- Project Selector -->
                <div class="p-4 border-b border-slate-800 bg-slate-900/50">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-[10px] font-bold text-slate-500 tracking-wider uppercase">Active Session</span>
                        <span id="ram-badge" class="text-[9px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1.5 py-0.5 rounded flex items-center gap-1 font-mono" title="Files stored securely in RAM">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> IN-MEMORY
                        </span>
                    </div>
                    <select id="project-selector" onchange="switchProject(this.value)" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-3 py-2 text-xs text-slate-200 font-semibold outline-none focus:ring-2 focus:ring-indigo-500 transition cursor-pointer appearance-none">
                        <option value="">No project loaded</option>
                    </select>
                </div>

                <!-- File Tree -->
                <div class="flex-1 flex flex-col overflow-hidden">
                    <div class="px-4 py-2.5 border-b border-slate-800 flex items-center justify-between bg-slate-950/30">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest flex items-center gap-1.5">
                            <i data-lucide="files" class="w-3 h-3"></i> Explorer
                        </span>
                        <span id="file-count-badge" class="text-[9px] text-slate-500 font-mono font-bold">0 files</span>
                    </div>
                    
                    <div id="file-tree-container" class="flex-1 overflow-y-auto py-2 px-1 font-mono text-[11px] text-slate-400">
                        <div class="text-center py-10 px-4">
                            <i data-lucide="folder-search" class="w-8 h-8 text-slate-700 mx-auto mb-3"></i>
                            <span class="text-slate-500 text-xs">Awaiting folder drop...</span>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- WORKSPACE EDITOR & VIEWER (Split Screen Workspace) -->
            <main class="flex-1 flex flex-col overflow-hidden relative">
                
                <!-- Browser Tabs -->
                <div class="bg-slate-900 border-b border-slate-800 h-11 flex items-end px-2 pt-2 shrink-0 overflow-x-auto select-none gap-1 justify-between">
                    <div id="tabs-container" class="flex items-center space-x-1 h-full scrollbar-none"></div>
                    <div class="px-3 pb-1.5 flex gap-2">
                        <button onclick="toggleEditorPanel()" id="btn-toggle-editor" class="text-[10px] bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold px-2.5 py-1 rounded transition flex items-center gap-1">
                            <i data-lucide="code" class="w-3.5 h-3.5"></i>
                            <span>Editor Panel</span>
                        </button>
                    </div>
                </div>

                <!-- Browser Address Bar -->
                <div class="bg-slate-900 border-b border-slate-800 px-4 py-2 flex items-center space-x-3 shrink-0">
                    <div class="flex items-center space-x-1">
                        <button onclick="activeTabHistoryBack()" class="p-1.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition"><i data-lucide="chevron-left" class="w-4 h-4"></i></button>
                        <button onclick="activeTabHistoryForward()" class="p-1.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition"><i data-lucide="chevron-right" class="w-4 h-4"></i></button>
                        <button onclick="reloadActiveTab()" class="p-1.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition"><i data-lucide="rotate-cw" class="w-3.5 h-3.5"></i></button>
                    </div>

                    <div class="flex-1 flex items-center bg-slate-950 border border-slate-700 rounded-lg px-3 py-1.5 text-xs text-slate-300 font-mono shadow-inner group focus-within:border-indigo-500 transition-colors">
                        <i data-lucide="lock" class="w-3 h-3 text-emerald-500 mr-2"></i>
                        <span class="text-slate-500 mr-0.5 select-none">localhost:3000/</span>
                        <input id="virtual-address-bar" type="text" class="bg-transparent border-none outline-none flex-1 text-slate-200" readonly placeholder="Waiting for connection...">
                    </div>

                    <button onclick="toggleConsole()" class="px-3 py-1.5 bg-slate-800 hover:bg-slate-700 border border-slate-600 text-slate-200 text-xs font-semibold rounded-lg transition flex items-center gap-1.5">
                        <i data-lucide="terminal-square" class="w-4 h-4 text-indigo-400"></i>
                        <span>Logs</span>
                    </button>
                </div>

                <!-- Loading State overlay -->
                <div id="loading-overlay" class="absolute inset-0 z-40 bg-slate-950 flex flex-col items-center justify-center hidden">
                    <span class="loader w-12 h-12 mb-4"></span>
                    <p class="text-sm font-bold text-indigo-400 animate-pulse">Processing Virtual File System...</p>
                </div>

                <!-- WORKBENCH: EDITOR & LIVE VIEW SPLIT -->
                <div class="flex-1 flex overflow-hidden bg-slate-950 relative">
                    <!-- Empty State -->
                    <div id="no-tabs-state" class="absolute inset-0 bg-slate-950 flex flex-col items-center justify-center text-center p-8 z-10">
                        <div class="relative group cursor-pointer mb-6" onclick="triggerFolderUpload()">
                            <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-emerald-500 rounded-full blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
                            <div class="relative bg-slate-900 border border-slate-700 w-24 h-24 rounded-full flex items-center justify-center shadow-2xl">
                                <i data-lucide="upload-cloud" class="w-10 h-10 text-indigo-400 group-hover:scale-110 transition-transform"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-2">Host Your Web Directory Natively</h3>
                        <p class="text-slate-400 text-sm max-w-md mb-8">Drag and drop any local folder here. The engine will instantly resolve all relative links, CSS, Javascript, and Images offline.</p>
                        
                        <div class="flex gap-4">
                            <button onclick="triggerFolderUpload()" class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold rounded-xl transition shadow-lg shadow-indigo-900/50">
                                Select Folder
                            </button>
                            <button onclick="loadDemoWorkspace()" class="px-6 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white text-sm font-bold rounded-xl transition">
                                Load Demo
                            </button>
                        </div>
                    </div>

                    <!-- LEFT SPLIT: REAL-TIME CODE EDITOR -->
                    <div id="editor-panel-split" class="w-1/2 border-r border-slate-800 flex flex-col bg-[#0b0f19] h-full hidden">
                        <!-- File Meta details -->
                        <div class="bg-slate-900 px-4 py-2 border-b border-slate-800 flex items-center justify-between text-xs text-slate-400">
                            <span class="font-mono flex items-center gap-1.5">
                                <i data-lucide="edit-3" class="w-3.5 h-3.5 text-indigo-400"></i>
                                <span id="editor-current-filename">index.html</span>
                            </span>
                            <div class="flex gap-2">
                                <button onclick="saveActiveFileEdits()" class="px-3 py-1 bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-bold rounded-md transition flex items-center gap-1">
                                    <i data-lucide="save" class="w-3 h-3"></i>
                                    Save & Reload
                                </button>
                            </div>
                        </div>

                        <!-- Editor Textarea Area -->
                        <div class="flex-1 flex relative overflow-hidden font-mono text-sm leading-relaxed p-4 bg-[#0a0d16]">
                            <!-- Synchronized line gutter -->
                            <div id="editor-gutter" class="w-10 shrink-0 text-slate-600 text-right pr-3 select-none border-r border-slate-800 text-[12px] font-mono leading-[20px] pt-1">
                                1
                            </div>
                            <!-- Editor Content Area -->
                            <textarea id="editor-textarea" onscroll="syncEditorScroll()" oninput="updateLineNumbers()" class="flex-1 h-full pl-3 bg-transparent text-indigo-200 border-none outline-none overflow-y-auto overflow-x-auto text-[12px] font-mono leading-[20px] pt-1" placeholder="<!-- Open a text-based file from the Explorer to begin editing -->" spellcheck="false"></textarea>
                        </div>
                    </div>

                    <!-- RIGHT SPLIT: PREVIEW SANDBOX PREVIEW -->
                    <div class="flex-1 h-full bg-white relative">
                        <div id="sandbox-iframe-container" class="w-full h-full relative"></div>
                    </div>
                </div>

                <!-- Dev Console -->
                <div id="developer-console" class="h-56 border-t border-slate-700 bg-slate-950 flex flex-col shrink-0 hidden shadow-2xl relative z-20">
                    <div class="bg-slate-900 px-4 py-2 border-b border-slate-800 flex items-center justify-between text-xs text-slate-300">
                        <div class="flex items-center gap-2 font-semibold text-indigo-400">
                            <i data-lucide="terminal" class="w-4 h-4"></i><span>Live Server Output</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <button onclick="clearConsole()" class="text-slate-400 hover:text-white transition hover:underline">Clear</button>
                            <button onclick="toggleConsole()" class="text-slate-400 hover:text-white transition"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                    </div>
                    <div id="console-logs-output" class="flex-1 overflow-y-auto p-3 font-mono text-[12px] space-y-1 text-slate-300 bg-[#0A0A0A]">
                        <div class="text-slate-500 italic">Listening for sandbox events...</div>
                    </div>
                </div>
            </main>
        </div>

        <!-- ========================================== -->
        <!-- MODE 2: UNRESTRICTED EXTERNAL WEB BROWSER  -->
        <!-- ========================================== -->
        <div id="view-external-browser" class="absolute inset-0 flex flex-col hidden bg-slate-950 z-30">
            <!-- Sleek Browser Address Bar -->
            <div class="bg-slate-900 border-b border-slate-800 p-3 flex items-center gap-3 shrink-0 shadow-md">
                <div class="flex items-center space-x-1">
                    <button class="p-1.5 text-slate-500 hover:text-slate-300 rounded transition"><i data-lucide="chevron-left" class="w-5 h-5"></i></button>
                    <button class="p-1.5 text-slate-500 hover:text-slate-300 rounded transition"><i data-lucide="chevron-right" class="w-5 h-5"></i></button>
                    <button onclick="loadExternalUrl()" class="p-1.5 text-slate-300 hover:text-white rounded transition"><i data-lucide="rotate-cw" class="w-4 h-4"></i></button>
                </div>

                <div class="flex-1 flex items-center bg-slate-950 border border-slate-700 focus-within:border-emerald-500 transition-colors rounded-full px-4 py-2 text-sm text-slate-200 shadow-inner group">
                    <i data-lucide="search" class="w-4 h-4 text-slate-500 mr-2 group-focus-within:text-emerald-500"></i>
                    <input id="external-url-input" type="url" class="bg-transparent border-none outline-none flex-1 text-white" placeholder="Enter URL (e.g., example.com)" onkeydown="if(event.key === 'Enter') loadExternalUrl()">
                </div>
                
                <!-- CORS Bypass Toggle -->
                <div class="flex items-center gap-2 bg-slate-800 px-3 py-1.5 rounded-full border border-slate-700" title="Bypasses X-Frame-Options to allow embedding">
                    <span class="text-[11px] font-bold text-slate-300 uppercase tracking-wide">Proxy Bypass</span>
                    <div class="relative inline-block w-8 mr-1 align-middle select-none transition duration-200 ease-in mt-0.5">
                        <input type="checkbox" name="toggle" id="use-proxy-toggle" class="toggle-checkbox absolute block w-4 h-4 rounded-full bg-white border-4 appearance-none cursor-pointer border-slate-400 z-10" checked/>
                        <label for="use-proxy-toggle" class="toggle-label block overflow-hidden h-4 rounded-full bg-slate-500 cursor-pointer"></label>
                    </div>
                </div>
            </div>

            <!-- Warning Banner -->
            <div class="bg-amber-500/10 border-b border-amber-500/20 px-4 py-1.5 flex items-center justify-center gap-2 text-[11px] text-amber-200/80 font-medium">
                <i data-lucide="shield-alert" class="w-3.5 h-3.5"></i>
                <span>Proxy mode strips security headers to allow embedding. Complex dynamic sites (like Google/Facebook) may still fail due to advanced scripts.</span>
            </div>

            <div class="flex-1 relative bg-white">
                <div id="browser-empty-state" class="absolute inset-0 bg-slate-950 flex flex-col items-center justify-center text-center p-8 z-10">
                    <div class="w-24 h-24 bg-slate-900 border border-slate-800 text-emerald-500 rounded-3xl flex items-center justify-center mb-6 shadow-2xl">
                        <i data-lucide="globe-2" class="w-12 h-12"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Unrestricted Proxy Viewer</h3>
                    <p class="text-slate-400 text-sm max-w-md">Type a web address in the top bar and press Enter. Ensure the Proxy Bypass is turned ON to view sites that typically block iframe embedding.</p>
                </div>
