    <!-- TOAST NOTIFICATIONS -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-[100] space-y-3 pointer-events-none flex flex-col items-end"></div>

    <script>
        // CORE STATE & USER SCHEMAS
        let workspaces = []; 
        let activeProjectId = null;
        let activeTabs = []; 
        let currentActiveTabId = null;
        
        let currentUser = null;
        let isSignUpMode = false;
        let activeEditorFilepath = null;

        // INDEXEDDB MANAGER (Partitioned securely per authenticated User UID)
        const DB_NAME = 'HyperLive_Secure_DB';
        const DB_VERSION = 1;
        const STORE_NAME = 'projects';
        let db = null;

        // Initialize IndexedDB
        function initDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open(DB_NAME, DB_VERSION);
                request.onupgradeneeded = (e) => {
                    const database = e.target.result;
                    if (!database.objectStoreNames.contains(STORE_NAME)) {
                        database.createObjectStore(STORE_NAME, { keyPath: 'storeKey' });
                    }
                };
                request.onsuccess = (e) => {
                    db = e.target.result;
                    resolve(db);
                };
                request.onerror = (e) => reject(e);
            });
        }

        // Save project specifically under the logged-in User's UID
        function saveProjectToLocalDatabase(project) {
            if (!db || !currentUser) return;
            const transaction = db.transaction([STORE_NAME], 'readwrite');
            const store = transaction.objectStore(STORE_NAME);
            
            // Format and pack for DB
            const formattedProject = {
                storeKey: `${currentUser.uid}_${project.id}`, // Securely scoped composite key
                userId: currentUser.uid,
                id: project.id,
                name: project.name,
                files: {}
            };

            Object.keys(project.files).forEach(path => {
                const f = project.files[path];
                formattedProject.files[path] = {
                    filename: f.filename,
                    vfsPath: f.vfsPath,
                    isText: f.isText,
                    content: f.content,
                    mimeType: f.mimeType,
                    fileObj: f.fileObj // File Blob values persist natively in IndexedDB
                };
            });

            store.put(formattedProject);
        }

        // Delete project from database
        function deleteProjectFromLocalDatabase(projectId) {
            if (!db || !currentUser) return;
            const transaction = db.transaction([STORE_NAME], 'readwrite');
            const store = transaction.objectStore(STORE_NAME);
            store.delete(`${currentUser.uid}_${projectId}`);
        }

        // Load files specifically saved by the active authenticated user
        function loadProjectsFromLocalDatabase() {
            return new Promise((resolve) => {
                if (!db || !currentUser) { resolve([]); return; }
                const transaction = db.transaction([STORE_NAME], 'readonly');
                const store = transaction.objectStore(STORE_NAME);
                const request = store.getAll();
                request.onsuccess = (e) => {
                    const allData = e.target.result || [];
                    // Filter matching current user UID only
                    const userProjects = allData.filter(p => p.userId === currentUser.uid);
                    resolve(userProjects);
                };
                request.onerror = () => resolve([]);
            });
        }

        /* ==================== FIREBASE AUTH SYSTEM ==================== */
