        // Open an editable text file directly inside the code editor splitscreen
        function openFileInEditor(vfsPath) {
            const project = workspaces.find(p => p.id === activeProjectId);
            if (!project) return;
            const file = project.files[vfsPath];
            if (!file) return;

            // Update UI Details
            activeEditorFilepath = vfsPath;
            document.getElementById('editor-current-filename').innerText = vfsPath;
            
            // Pop open Editor view panel if closed
            const panel = document.getElementById('editor-panel-split');
            if (panel.classList.contains('hidden')) {
                toggleEditorPanel();
            }

            // Put file contents into the Editor Textarea
            const textarea = document.getElementById('editor-textarea');
            textarea.value = file.content || "";
            updateLineNumbers();
        }

        // Synchronize scroll on textarea with the line-number gutter
        function syncEditorScroll() {
            const textarea = document.getElementById('editor-textarea');
            const gutter = document.getElementById('editor-gutter');
            gutter.scrollTop = textarea.scrollTop;
        }

        // Update gutter counts in alignment with text breaks
        function updateLineNumbers() {
            const textarea = document.getElementById('editor-textarea');
            const gutter = document.getElementById('editor-gutter');
            const lines = textarea.value.split('\n').length;
            
            let gutterHTML = '';
            for (let i = 1; i <= lines; i++) {
                gutterHTML += `<div>${i}</div>`;
            }
            gutter.innerHTML = gutterHTML;
        }

        // Save modified file changes back into VFS and hot-reload active iframe
        function saveActiveFileEdits() {
            if (!activeProjectId || !activeEditorFilepath) return;
            const project = workspaces.find(p => p.id === activeProjectId);
            if (!project) return;
            const file = project.files[activeEditorFilepath];
            if (!file) return;

            const updatedContent = document.getElementById('editor-textarea').value;
            file.content = updatedContent;

            // Push database updates locally
            saveProjectToLocalDatabase(project);

            showToast(`Saved changes successfully!`, "success");
            addLogToConsole(`Code updated: /${activeEditorFilepath}. Hot-reloading active preview...`, 'system');

            // Find matching tab session and reload frame instantly
            const tab = activeTabs.find(t => t.projectId === activeProjectId && t.tabId === currentActiveTabId);
            if (tab) {
                compileAndLoadIFrame(tab);
            }
        }

        /* ==================== DRAG & DROP FOLDER ENGINE ==================== */
        function triggerFolderUpload() { document.getElementById('folder-upload-input').click(); }
        
        function setupDragAndDrop() {
            const body = document.body;
            ['dragenter', 'dragover'].forEach(evt => {
                body.addEventListener(evt, (e) => {
                    e.preventDefault(); e.stopPropagation();
                    body.classList.add('drag-active');
                }, false);
            });
            ['dragleave', 'drop'].forEach(evt => {
                body.addEventListener(evt, (e) => {
                    e.preventDefault(); e.stopPropagation();
                    if (e.target === document.getElementById('global-drop-overlay') || evt === 'drop') {
                        body.classList.remove('drag-active');
                    }
                }, false);
            });

            body.addEventListener('drop', async (e) => {
                const items = e.dataTransfer.items;
                if (!items || !currentUser) return;

                document.getElementById('loading-overlay').classList.remove('hidden');
                const projectFiles = {};
                let projectName = "My_Project";

                try {
                    for (let i = 0; i < items.length; i++) {
                        const item = items[i].webkitGetAsEntry();
                        if (item) {
                            if (item.isDirectory && projectName === "My_Project") projectName = item.name;
                            await traverseFileTree(item, "", projectFiles);
                        }
                    }

                    if (Object.keys(projectFiles).length > 0) {
                        createNewProjectWorkspace(projectName, projectFiles);
                    } else {
                        showToast("No readable files found in drop.", "error");
                    }
                } catch (error) {
                    showToast("Error reading dropped files.", "error");
                } finally {
                    document.getElementById('loading-overlay').classList.add('hidden');
                }
            });
        }

        async function traverseFileTree(item, path, projectFiles) {
            path = path || "";
            if (item.isFile) {
                const file = await new Promise((resolve) => item.file(resolve));
                const vfsPath = path + item.name;
                const isText = isTextFile(item.name);
                let content = null;
                if (isText) content = await file.text();

                projectFiles[vfsPath] = {
                    filename: item.name,
                    vfsPath: vfsPath,
                    isText: isText,
                    content: content,
                    mimeType: file.type || getMimeType(item.name),
                    fileObj: file 
                };
            } else if (item.isDirectory) {
                const dirReader = item.createReader();
                const entries = await new Promise((resolve) => dirReader.readEntries(resolve));
                for (let i = 0; i < entries.length; i++) {
                    await traverseFileTree(entries[i], path + item.name + "/", projectFiles);
                }
            }
        }

        async function handleFolderUpload(event) {
            const files = event.target.files;
            if (files.length === 0 || !currentUser) return;
            document.getElementById('loading-overlay').classList.remove('hidden');
            
            setTimeout(async () => {
                const projectFiles = {};
                let projectName = "Uploaded_Folder";

                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    const parts = file.webkitRelativePath.split('/');
                    projectName = parts[0];
                    const vfsPath = parts.slice(1).join('/');

                    const isText = isTextFile(file.name);
                    let content = null;
                    if (isText) content = await file.text();

                    projectFiles[vfsPath] = {
                        filename: file.name, vfsPath: vfsPath, isText: isText,
                        content: content, mimeType: file.type || getMimeType(file.name), fileObj: file
                    };
                }
                document.getElementById('loading-overlay').classList.add('hidden');
                createNewProjectWorkspace(projectName, projectFiles);
                event.target.value = ''; 
            }, 100);
        }

        function createNewProjectWorkspace(name, projectFiles) {
            if (!projectFiles['index.html']) {
                projectFiles['index.html'] = {
                    filename: 'index.html', vfsPath: 'index.html', isText: true,
                    content: `<!DOCTYPE html><html><body style="background:#0f172a;color:#fff;font-family:sans-serif;padding:40px;text-align:center;"><h2>Local Host Active</h2><p>Folder mounted successfully. Total files: ${Object.keys(projectFiles).length}</p></body></html>`,
                    mimeType: 'text/html', fileObj: null
                };
            }

            const newProject = { id: 'proj-' + Date.now(), name: name, files: projectFiles };
            workspaces.push(newProject);
            
            // Save to browser persistent database (IndexedDB)
            saveProjectToLocalDatabase(newProject);
            
            // Show export button now that we have data
            document.getElementById('btn-export-zip').classList.remove('hidden');
            document.getElementById('btn-export-zip').classList.add('flex');

            populateProjectSelector();
            switchProject(newProject.id);
            showToast(`Mounted folder "${name}"!`, "success");
        }

        function populateProjectSelector() {
            const selector = document.getElementById('project-selector');
            selector.innerHTML = '';
            if (workspaces.length === 0) {
                selector.innerHTML = '<option value="">No project loaded</option>';
                return;
            }
            workspaces.forEach(proj => {
                const opt = document.createElement('option');
                opt.value = proj.id; opt.innerText = proj.name;
                if (proj.id === activeProjectId) opt.selected = true;
                selector.appendChild(opt);
            });
        }

        function switchProject(projectId) {
            activeProjectId = projectId;
            const project = workspaces.find(p => p.id === projectId);
            const fileTree = document.getElementById('file-tree-container');
            const fileBadge = document.getElementById('file-count-badge');

            if (!project) {
                fileTree.innerHTML = `<div class="text-center py-10 px-4"><span class="text-slate-500 text-xs">Awaiting folder drop...</span></div>`;
                fileBadge.innerText = '0 files';
                return;
            }

            fileBadge.innerText = `${Object.keys(project.files).length} files`;
            renderFileTreeStructure(project.files);
            openAppInTab(project.id);
        }

        /* ==================== FILE EXPLORER UI ==================== */
        function renderFileTreeStructure(files) {
            const container = document.getElementById('file-tree-container');
            container.innerHTML = '';
            const root = { files: [], dirs: {} };

            // Build hierarchical object
            Object.keys(files).forEach(path => {
                const parts = path.split('/');
                let current = root;
                for (let i = 0; i < parts.length; i++) {
                    const part = parts[i];
                    if (i === parts.length - 1) current.files.push({ name: part, fullPath: path });
                    else {
                        if (!current.dirs[part]) current.dirs[part] = { files: [], dirs: {} };
                        current = current.dirs[part];
                    }
                }
            });

            // Render DOM recursively
            function buildHtmlTree(node, depth, parentNode) {
                Object.keys(node.dirs).sort().forEach(dirName => {
                    const folderDiv = document.createElement('div');
                    folderDiv.className = "flex flex-col select-none";
                    const folderHeader = document.createElement('div');
                    folderHeader.className = "flex items-center space-x-2 py-1.5 px-2 rounded cursor-pointer tree-item-hover transition";
                    folderHeader.style.paddingLeft = `${depth * 12 + 8}px`;
                    folderHeader.innerHTML = `<i data-lucide="folder" class="w-3.5 h-3.5 text-indigo-400 shrink-0 fill-indigo-900/30"></i><span class="font-medium truncate">${dirName}</span>`;
                    
                    const folderChildren = document.createElement('div');
                    folderChildren.className = "flex flex-col border-l border-slate-800 ml-4 pl-1";
                    
                    folderHeader.onclick = () => folderChildren.classList.toggle('hidden');
                    folderDiv.appendChild(folderHeader); folderDiv.appendChild(folderChildren);
                    parentNode.appendChild(folderDiv);
                    buildHtmlTree(node.dirs[dirName], depth + 1, folderChildren);
                });

                node.files.sort((a,b) => a.name.localeCompare(b.name)).forEach(file => {
                    const fileDiv = document.createElement('div');
                    fileDiv.className = "flex items-center space-x-2 py-1.5 px-2 rounded cursor-pointer tree-item-hover transition";
                    fileDiv.style.paddingLeft = `${depth * 12 + 8}px`;
                    
                    let icon = 'file-code'; let iconColor = 'text-indigo-400';
                    const ext = file.name.split('.').pop().toLowerCase();
                    if (ext === 'html') { icon = 'file-html'; iconColor = 'text-orange-400'; }
                    else if (ext === 'css') { icon = 'file-type-css'; iconColor = 'text-sky-400'; }
                    else if (ext === 'js') { icon = 'file-type-js'; iconColor = 'text-yellow-400'; }
                    else if (['png','jpg','jpeg','gif','svg','webp'].includes(ext)) { icon = 'image'; iconColor = 'text-emerald-400'; }
                    
                    fileDiv.innerHTML = `<i data-lucide="${icon}" class="w-3.5 h-3.5 ${iconColor} shrink-0"></i><span class="truncate text-slate-300 font-mono">${file.name}</span>`;
                    fileDiv.onclick = () => {
                        openFileInTab(file.fullPath);
                        if (isTextFile(file.name)) {
                            openFileInEditor(file.fullPath);
                        }
                    };
                    parentNode.appendChild(fileDiv);
                });
            }
            buildHtmlTree(root, 0, container);
            lucide.createIcons();
        }

        /* ==================== TAB SYSTEM & ROUTER ==================== */
        function openFileInTab(vfsPath) {
            if (!activeProjectId) return;
            const tab = activeTabs.find(t => t.projectId === activeProjectId && t.tabId === currentActiveTabId);
            if (tab) routeToPage(activeProjectId, vfsPath);
            else openAppInTab(activeProjectId, vfsPath);
        }

        function openAppInTab(projectId, startFile = 'index.html') {
            const existingTab = activeTabs.find(t => t.projectId === projectId && t.currentFilename === startFile);
            if (existingTab) { activateTab(existingTab.tabId); return; }
            
            const tabId = 'tab-' + Date.now();
            activeTabs.push({ tabId, projectId, currentFilename: startFile, historyQueue: [startFile], historyIndex: 0 });
            renderTabs(); activateTab(tabId);
        }

        function renderTabs() {
            const container = document.getElementById('tabs-container');
            container.innerHTML = '';
            activeTabs.forEach(tab => {
                const project = workspaces.find(p => p.id === tab.projectId);
                if (!project) return;
                const isActive = tab.tabId === currentActiveTabId;
                const activeClasses = isActive 
                    ? 'bg-slate-950 border-t-2 border-t-indigo-500 text-slate-100 border-x border-slate-800' 
                    : 'bg-slate-900 text-slate-500 hover:text-slate-300 border-x border-transparent hover:bg-slate-850';
                
                const tabNode = document.createElement('div');
                tabNode.className = `h-9 px-3 flex items-center space-x-2 text-[11px] font-medium cursor-pointer transition-all ${activeClasses} rounded-t-lg shrink-0 mt-1`;
                tabNode.onclick = () => { if (activeProjectId !== tab.projectId) switchProject(tab.projectId); activateTab(tab.tabId); };
                tabNode.innerHTML = `<span class="max-w-[120px] truncate font-mono">${tab.currentFilename}</span>
                    <button onclick="closeTab('${tab.tabId}', event)" class="hover:text-rose-400 ml-1 rounded hover:bg-slate-800 p-0.5 transition"><i data-lucide="x" class="w-3 h-3"></i></button>`;
                container.appendChild(tabNode);
            });
            lucide.createIcons();
        }

        function activateTab(tabId) {
            currentActiveTabId = tabId; renderTabs();
            const tab = activeTabs.find(t => t.tabId === tabId);
            
            if (!tab) {
                document.getElementById('no-tabs-state').classList.remove('hidden');
                document.getElementById('virtual-address-bar').value = '';
                return;
            }
            document.getElementById('no-tabs-state').classList.add('hidden');
            document.getElementById('virtual-address-bar').value = tab.currentFilename;
            compileAndLoadIFrame(tab);
        }

        function closeTab(tabId, event) {
            if (event) event.stopPropagation();
            activeTabs = activeTabs.filter(t => t.tabId !== tabId); renderTabs();
            if (currentActiveTabId === tabId) activateTab(activeTabs.length > 0 ? activeTabs[activeTabs.length - 1].tabId : null);
        }

        function closeAllTabs() { activeTabs = []; activateTab(null); }
        function reloadActiveTab() { if(currentActiveTabId) activateTab(currentActiveTabId); }

        function routeToPage(projectId, targetFilename) {
            const activeTab = activeTabs.find(t => t.projectId === projectId && t.tabId === currentActiveTabId);
            if (!activeTab) return;
            const pure = targetFilename.split(/[?#]/)[0];
            activeTab.historyQueue = activeTab.historyQueue.slice(0, activeTab.historyIndex + 1);
            activeTab.historyQueue.push(pure); activeTab.historyIndex++;
            activeTab.currentFilename = pure; activateTab(activeTab.tabId);
        }

        function activeTabHistoryBack() {
            const tab = activeTabs.find(t => t.tabId === currentActiveTabId);
            if (tab && tab.historyIndex > 0) { tab.historyIndex--; tab.currentFilename = tab.historyQueue[tab.historyIndex]; activateTab(tab.tabId); }
        }

        function activeTabHistoryForward() {
            const tab = activeTabs.find(t => t.tabId === currentActiveTabId);
            if (tab && tab.historyIndex < tab.historyQueue.length - 1) { tab.historyIndex++; tab.currentFilename = tab.historyQueue[tab.historyIndex]; activateTab(tab.tabId); }
        }

        /* ==================== VFS HTML COMPILER ==================== */
        function compileHTML(project, filename) {
            const page = project.files[filename];
            if (!page) return null;

            // Render non-HTML files gracefully in the sandbox view
            if (!filename.toLowerCase().endsWith('.html') && !filename.toLowerCase().endsWith('.htm')) {
                const ext = filename.split('.').pop().toLowerCase();
                if (['png','jpg','jpeg','gif','webp','svg'].includes(ext)) {
                    const url = page.fileObj ? URL.createObjectURL(page.fileObj) : '';
                    return `<!DOCTYPE html><html><body style="background:#020617;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;"><img src="${url}" style="max-width:90%;max-height:90%;border-radius:8px;box-shadow:0 10px 25px rgba(0,0,0,0.5);"/></body></html>`;
                }
                const content = escapeHTML(page.content || "/* Binary Data */");
                return `<!DOCTYPE html><html><body style="background:#020617;color:#38bdf8;font-family:'JetBrains Mono',monospace;white-space:pre-wrap;padding:20px;font-size:13px;line-height:1.5;">${content}</body></html>`;
            }

            // Parse HTML to inject local assets
            const parser = new DOMParser();
            const doc = parser.parseFromString(page.content, 'text/html');

            doc.querySelectorAll('link[rel="stylesheet"]').forEach(link => {
                const href = link.getAttribute('href');
                const res = project.files[resolveRelativePath(filename, href)];
                if (res) { const s = doc.createElement('style'); s.textContent = res.content; link.replaceWith(s); }
            });

            doc.querySelectorAll('script[src]').forEach(script => {
                const src = script.getAttribute('src');
                const res = project.files[resolveRelativePath(filename, src)];
                if (res) { const s = doc.createElement('script'); s.textContent = res.content; script.replaceWith(s); }
            });

            doc.querySelectorAll('img[src]').forEach(img => {
                const src = img.getAttribute('src');
                const res = project.files[resolveRelativePath(filename, src)];
                if (res && res.fileObj) img.setAttribute('src', URL.createObjectURL(res.fileObj));
            });

            doc.querySelectorAll('a[href]').forEach(a => {
                const href = a.getAttribute('href');
                if (href && !/^(http|\/\/|#|javascript:)/i.test(href)) {
                    const resolved = resolveRelativePath(filename, href);
                    a.setAttribute('onclick', `window.parent.routeToPage('${project.id}', '${resolved}'); return false;`);
                    a.setAttribute('href', '#');
                }
            });

            // Inject Console Interceptor
            const loggerScript = doc.createElement('script');
            loggerScript.textContent = `
                (function(){
                    const p = window.parent;
                    function send(lvl, msg) { p.postMessage({type:'SANDBOX_LOG', level:lvl, message:msg}, '*'); }
                    const _log = console.log, _err = console.error;
                    console.log = (...args) => { send('info', args.map(a => typeof a==='object'?JSON.stringify(a):String(a)).join(' ')); _log(...args); };
                    console.error = (...args) => { send('error', args.map(a => typeof a==='object'?JSON.stringify(a):String(a)).join(' ')); _err(...args); };
                    window.addEventListener('error', e => send('error', 'Uncaught: ' + e.message + ' at line ' + e.lineno));
                })();
            `;
            doc.head.insertBefore(loggerScript, doc.head.firstChild);

            // Reconstruct HTML with Doctype
            return '<!DOCTYPE html>\n' + doc.documentElement.outerHTML;
        }

        function compileAndLoadIFrame(tab) {
            const project = workspaces.find(p => p.id === tab.projectId);
            const compiledSource = project ? compileHTML(project, tab.currentFilename) : null;
            
            const container = document.getElementById('sandbox-iframe-container');
            container.innerHTML = '';
            const iframe = document.createElement('iframe');
            iframe.className = 'sandbox-iframe bg-white';
            iframe.sandbox = 'allow-scripts allow-forms allow-popups allow-modals allow-same-origin';
            container.appendChild(iframe);

            const doc = iframe.contentWindow.document;
            doc.open();
            if (compiledSource) {
                doc.write(compiledSource);
                addLogToConsole(`Served: /${tab.currentFilename}`, 'system');
            } else {
                doc.write(`<!DOCTYPE html><html><body style="background:#0f172a;color:#fff;font-family:sans-serif;text-align:center;padding-top:100px;"><h1>404 - File Not Found</h1><p style="color:#94a3b8;">${tab.currentFilename}</p></body></html>`);
            }
            doc.close();
        }

        /* ==================== DEV CONSOLE ==================== */
        function toggleConsole() { document.getElementById('developer-console').classList.toggle('hidden'); }
        function clearConsole() { document.getElementById('console-logs-output').innerHTML = ''; }
        function handleSandboxMessages(event) {
            if (!event.data || !currentActiveTabId) return;
            const tab = activeTabs.find(t => t.tabId === currentActiveTabId);
            if (!tab) return;
            if (event.data.type === 'SANDBOX_LOG') addLogToConsole(`[Frame] ${event.data.message}`, event.data.level);
        }
        function addLogToConsole(text, level) {
            const c = document.getElementById('console-logs-output');
            const d = document.createElement('div');
            d.className = `font-mono pb-1 border-b border-[#222] ${level==='error'?'text-rose-400': level==='system'?'text-indigo-400':'text-slate-300'}`;
            d.innerText = `> ${text}`;
            c.appendChild(d); c.scrollTop = c.scrollHeight;
        }

        function updateFirebaseTriggerButtonState(active) {
            // Unused as config triggers were replaced by premium Auth states.
        }

        // Auto Load offline workspaces from persistent repository DB
        async function autoLoadOfflineFolders() {
            document.getElementById('loading-overlay').classList.remove('hidden');
            try {
                const localProjects = await loadProjectsFromLocalDatabase();
                if (localProjects && localProjects.length > 0) {
                    workspaces = localProjects;
                    populateProjectSelector();
                    switchProject(workspaces[workspaces.length - 1].id);
                    document.getElementById('btn-export-zip').classList.remove('hidden');
                    document.getElementById('btn-export-zip').classList.add('flex');
                    showToast(`Restored ${workspaces.length} projects from local database!`, "success");
                } else {
                    workspaces = [];
                    populateProjectSelector();
                    switchProject(null);
                    closeAllTabs();
                }
            } catch (err) {
                console.error("VFS retrieval error:", err);
            } finally {
                document.getElementById('loading-overlay').classList.add('hidden');
            }
        }

        /* ==================== EXPORT & UTILS ==================== */
        async function exportWorkspaceToZip() {
            if (!activeProjectId) return;
            const project = workspaces.find(p => p.id === activeProjectId);
            if (!project) return;
            
            if (typeof JSZip === 'undefined') {
                showToast("ZIP Engine loading, please wait...", "info");
                return;
            }

            const zip = new JSZip();
            const root = zip.folder(project.name);

            // Add all files to the ZIP
            Object.values(project.files).forEach(file => {
                if (file.fileObj) {
                    root.file(file.vfsPath, file.fileObj); // Binary / native objects
                } else {
                    root.file(file.vfsPath, file.content); // Text contents
                }
            });

            showToast("Packaging ZIP file...", "info");
            try {
                const content = await zip.generateAsync({ type: "blob" });
                const url = window.URL.createObjectURL(content);
                const a = document.createElement('a');
                a.style.display = 'none';
                a.href = url;
                a.download = `${project.name}_export.zip`;
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                showToast("Workspace Exported Successfully!", "success");
            } catch (err) {
                showToast("Failed to create ZIP package.", "error");
            }
        }

        function clearAllWorkspaceStates() {
            workspaces = []; activeTabs = []; currentActiveTabId = null; activeProjectId = null;
            document.getElementById('btn-export-zip').classList.add('hidden');
            populateProjectSelector(); switchProject(null); closeAllTabs();
        }

        function clearAllWorkspaces() {
            if (workspaces.length === 0) return;
            if (confirm("Clear all active projects from browser memory and IndexedDB storage?")) {
                workspaces.forEach(proj => deleteProjectFromLocalDatabase(proj.id));
                clearAllWorkspaceStates();
                showToast("Memory databases purged completely.", "info");
            }
        }

        function loadDemoWorkspace() {
            const demoFiles = {
                'index.html': { filename: 'index.html', vfsPath: 'index.html', isText: true, mimeType: 'text/html', content: `<!DOCTYPE html>\n<html lang="en">\n<head>\n<meta charset="UTF-8">\n<title>Demo Site</title>\n<link rel="stylesheet" href="css/style.css">\n</head>\n<body>\n<div class="container">\n<h1>Hello HyperLive</h1>\n<p>This is an offline demo running via an isolated Virtual File System.</p>\n<a href="pages/about.html" class="btn">Go to About Page</a>\n<button class="btn" onclick="console.log('Button clicked!')">Test Console Log</button>\n</div>\n</body>\n</html>`},
                'css/style.css': { filename: 'style.css', vfsPath: 'css/style.css', isText: true, mimeType: 'text/css', content: `body { font-family: system-ui, sans-serif; background: #0f172a; color: #fff; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }\n.container { background: #1e293b; padding: 40px; border-radius: 16px; border: 1px solid #334155; text-align: center; }\n.btn { display: inline-block; margin-top: 16px; padding: 10px 20px; background: #6366f1; color: white; text-decoration: none; border-radius: 8px; border: none; cursor: pointer; }\n.btn:hover { background: #4f46e5; }`},
                'pages/about.html': { filename: 'about.html', vfsPath: 'pages/about.html', isText: true, mimeType: 'text/html', content: `<!DOCTYPE html>\n<html lang="en">\n<head>\n<title>About</title>\n<link rel="stylesheet" href="../css/style.css">\n</head>\n<body>\n<div class="container">\n<h1>Relative Routing Works!</h1>\n<p>The stylesheet was successfully linked using "../css/style.css".</p>\n<a href="../index.html" class="btn">Back to Home</a>\n</div>\n</body>\n</html>`}
            };
            createNewProjectWorkspace("Demo_Project", demoFiles);
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            const icon = type === 'success' ? 'check-circle' : (type === 'error' ? 'alert-triangle' : 'info');
            const color = type === 'success' ? 'text-emerald-400 border-emerald-500/50' : (type === 'error' ? 'text-rose-400 border-rose-500/50' : 'text-indigo-400 border-indigo-500/50');
            toast.className = `flex items-center gap-3 p-3 rounded-lg bg-slate-900 border ${color} shadow-xl transition-all duration-300 translate-x-12 opacity-0 text-sm font-medium`;
            toast.innerHTML = `<i data-lucide="${icon}" class="w-4 h-4 shrink-0"></i> <span>${message}</span>`;
            container.appendChild(toast);
            lucide.createIcons();
            setTimeout(() => toast.classList.remove('translate-x-12', 'opacity-0'), 10);
            setTimeout(() => { toast.classList.add('translate-x-12', 'opacity-0'); setTimeout(() => toast.remove(), 300); }, 3000);
        }

        function isTextFile(fn) { return ['html', 'htm', 'css', 'js', 'json', 'txt', 'svg', 'md'].includes(fn.split('.').pop().toLowerCase()); }
        function getMimeType(fn) {
            const map = { 'html':'text/html', 'css':'text/css', 'js':'application/javascript', 'png':'image/png', 'jpg':'image/jpeg', 'svg':'image/svg+xml' };
            return map[fn.split('.').pop().toLowerCase()] || 'application/octet-stream';
        }
        function escapeHTML(str) { return str.replace(/[&<>'"]/g, t => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[t]||t)); }
    </script>
